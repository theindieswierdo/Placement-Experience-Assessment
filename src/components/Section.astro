---
export interface Props{
    id: string;
    title: string;
    soundfile: string;
}
const { id, title, soundfile } = Astro.props;
import icon from '../assets/images/sound.svg';

---
<section id={id} class="border-2 border-black-300 mb-8 bg-[var(--surface)]">
    <div class="p-6">
        <h2 class="text-2xl">{title}</h2>
        <div>
            <div class="flex items-center gap-4">
                <img class="m-2 p-2" width="100" height="100" src={icon.src}/>
                <audio controls>
                    <source src={soundfile} type="audio/mpeg">
                </audio>
            </div>
            <slot />
            
        </div>
    </div>
</section>